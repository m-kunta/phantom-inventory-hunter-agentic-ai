# Copy this file to .env and fill in your real values.
# Never commit .env to version control.
#
# Only the key for your chosen provider is required.
# Set LLM_PROVIDER to the display name of your chosen provider.

# ─── Provider Selection ────────────────────────────────────────────────────
# Options: Gemini | OpenAI | Anthropic | Groq | Ollama
LLM_PROVIDER=Gemini

# ─── Provider API Keys (fill in only the one(s) you use) ──────────────────
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# ─── Ollama (local, no API key needed) ────────────────────────────────────
# Make sure Ollama is running: https://ollama.com
# Pull the model first: ollama pull llama3.2
